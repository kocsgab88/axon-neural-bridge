# AXON Neural Bridge – környezeti változók
# Másold át .env-re és töltsd ki az értékeket
# SOHA ne commitold a .env fájlt!

# Telegram Bot Token (https://t.me/BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Anthropic API Key (https://console.anthropic.com)
ANTHROPIC_KEY=your_anthropic_api_key_here

# Google Gemini API Key – PAID TIER kötelező!
# (Free tier engedi a Google-nek a promptokat tanításhoz – ügyfél kód nem kerülhet oda)
# https://aistudio.google.com/app/apikey
GEMINI_KEY=your_gemini_api_key_here
